# Google サービスアカウント JSON キーのホスト側パス
GCP_KEY_PATH=/path/to/your/gcp-key.json

# Google スプレッドシート ID（URL の /d/{ID}/edit の部分）
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# フロントエンドが API を叩く先（ビルド時に焼き込まれる）
# LAN 越しアクセス時は iMac の IP に変更（例: http://192.168.1.10:8081）
# 同一マシンのブラウザからのみ使う場合はこのまま
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081

# Slack Webhook URL と有効フラグ
SLACK_WEBHOOK__URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_ENABLED=true
